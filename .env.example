# Copy to .env.local for local development. Never commit filled-in env files.
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/arteffect
PAYLOAD_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional when running behind a known number of trusted proxies.
RATE_LIMIT_TRUSTED_PROXY_HOPS=0
